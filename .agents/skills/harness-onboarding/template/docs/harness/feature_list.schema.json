{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness-template.local/schemas/feature_list.schema.json",
  "title": "harness-template feature list",
  "description": "Schema para feature_list.json (backlog activo) y feature_list.archive.json (features done archivadas). El archivo de archivo usa el schema definido en $defs/archive_file.",
  "$comment": "Este schema es referencial (ayuda a IDEs y linters). La fuente normativa de validación operativa es scripts/validate_harness.py.",
  "$defs": {
    "feature": {
      "type": "object",
      "required": ["id", "name", "title", "description", "acceptance", "status"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "acceptance": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "done", "blocked"]
        }
      }
    },
    "archived_feature": {
      "$ref": "#/$defs/feature",
      "description": "Feature archivada: status debe ser 'done'"
    },
    "archive_file": {
      "type": "object",
      "description": "Schema de feature_list.archive.json: archivo de features con status done.",
      "required": ["project", "description", "features"],
      "additionalProperties": false,
      "properties": {
        "project": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "features": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/archived_feature"
          }
        }
      }
    }
  },
  "type": "object",
  "required": ["project", "description", "rules", "features"],
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "rules": {
      "type": "object",
      "required": [
        "one_feature_at_a_time",
        "require_tests_to_close",
        "max_review_iterations",
        "valid_status"
      ],
      "additionalProperties": false,
      "properties": {
        "one_feature_at_a_time": {
          "type": "boolean",
          "const": true
        },
        "require_tests_to_close": {
          "type": "boolean",
          "const": true
        },
        "max_review_iterations": {
          "type": "integer",
          "minimum": 1
        },
        "reports_required_from_id": {
          "type": "integer",
          "minimum": 1,
          "description": "ID mínimo de feature a partir del cual se exigen impl_* y review_* para status done"
        },
        "valid_status": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["pending", "in_progress", "done", "blocked"]
          }
        }
      }
    },
    "features": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/feature"
      }
    }
  }
}
